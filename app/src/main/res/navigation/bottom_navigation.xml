<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottom_navigation"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.qbs.laafresh.ui.fragments.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home">

        <action
            android:id="@+id/action_homeFragment_to_productFragment"
            app:destination="@id/productFragment" />
        <action
            android:id="@+id/action_homeFragment_to_productDetailsFragment"
            app:destination="@id/productDetailsFragment" />

        <action
            android:id="@+id/action_homeFragment_to_addingToCartFragment"
            app:destination="@id/addingToCartFragment" />
    </fragment>
    <fragment
        android:id="@+id/favoriteFragment"
        android:name="com.qbs.laafresh.ui.fragments.favorite.FavoriteFragment"
        android:label="fragment_favorite"
        tools:layout="@layout/fragment_favorite">
        <action
            android:id="@+id/action_favoriteFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_favoriteFragment_to_productDetailsFragment"
            app:destination="@id/productDetailsFragment" />
        <action
            android:id="@+id/action_favoriteFragment_to_addingToCartFragment"
            app:destination="@id/addingToCartFragment" />


    </fragment>
    <fragment
        android:id="@+id/myOrdersFragment"
        android:name="com.qbs.laafresh.ui.fragments.orders.MyOrdersFragment"
        android:label="fragment_my_orders"
        tools:layout="@layout/fragment_my_orders" />
    <fragment
        android:id="@+id/myCartFragment"
        android:name="com.qbs.laafresh.ui.fragments.cart.MyCartFragment"
        android:label="fragment_my_cart"
        tools:layout="@layout/fragment_my_cart" >
        <action
            android:id="@+id/action_myCartFragment_to_checkOutFragment"
            app:destination="@id/checkOutFragment" />
        <action
            android:id="@+id/action_myCartFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@+id/homeFragment"
            app:popUpToInclusive="true"/>
    </fragment>

    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.qbs.laafresh.ui.fragments.settings.SettingsFragment"
        android:label="fragment_settings"
        tools:layout="@layout/fragment_settings">

        <action
            android:id="@+id/action_addAddressFragment_to_settingsFragment"
            app:destination="@id/addAddressFragment" />
        <action
            android:id="@+id/action_addAddressFragment_to_webViewFragment"
            app:destination="@id/webViewFragment" />
    </fragment>
    <fragment
        android:id="@+id/productFragment"
        android:name="com.qbs.laafresh.ui.fragments.products.ProductFragment"
        android:label="ProductFragment">
        <action
            android:id="@+id/action_productFragment_to_productDetailsFragment"
            app:destination="@id/productDetailsFragment" />
        <action
            android:id="@+id/action_productFragment_to_addingToCartFragment"
            app:destination="@id/addingToCartFragment" />
        <action
            android:id="@+id/action_productFragment_to_mycartFragment"
            app:destination="@id/myCartFragment" />
    </fragment>
    <fragment
        android:id="@+id/productDetailsFragment"
        android:name="com.qbs.laafresh.ui.fragments.products.ProductDetailsFragment"
        android:label="ProductDetailsFragment" />
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.qbs.laafresh.ui.fragments.login.LoginFragment"
        android:label="LoginFragment">
        <action
            android:id="@+id/action_loginFragment_to_productFragment"
            app:destination="@id/productFragment" />
        <action
            android:id="@+id/action_loginFragment_to_forgetFragment"
            app:destination="@id/forgetFragment" />
        <action
            android:id="@+id/action_loginFragment_to_signUpFragment"
            app:destination="@id/signUpFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:launchSingleTop="true"
            app:popUpTo="@+id/main_nav_graph"
            app:popUpToInclusive="true" />

    </fragment>
    <fragment
        android:id="@+id/forgetFragment"
        android:name="com.qbs.laafresh.ui.fragments.login.ForgetFragment"
        android:label="ForgetFragment">
        <action
            android:id="@+id/action_forgetFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/signUpFragment"
        android:name="com.qbs.laafresh.ui.fragments.login.SignUpFragment"
        android:label="SignUpFragment">
        <action
            android:id="@+id/action_signUpFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>
    <fragment
        android:id="@+id/addAddressFragment"
        android:name="com.qbs.laafresh.ui.fragments.settings.AddAddressFragment"
        android:label="AddAddressFragment">
        <action
            android:id="@+id/action_addAddressFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/webViewFragment"
        android:name="com.qbs.laafresh.ui.fragments.settings.WebViewFragment"
        android:label="WebViewFragment" />
    <fragment
        android:id="@+id/addingToCartFragment"
        android:name="com.qbs.laafresh.ui.fragments.cart.AddingToCartFragment"
        android:label="AddingToCartFragment" >
        <action
            android:id="@+id/action_addAddressFragment_to_mycartFragment"
            app:destination="@id/myCartFragment" />

    </fragment>
    <fragment
        android:id="@+id/checkOutFragment"
        android:name="com.qbs.laafresh.ui.fragments.checkout.CheckOutFragment"
        android:label="fragment_check_out"
        tools:layout="@layout/fragment_check_out" >
        <action
            android:id="@+id/action_checkOutFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_checkOutFragment_to_instaMojoWebViewFragment"
            app:destination="@id/instaMojoWebViewFragment" />

    </fragment>
    <fragment
        android:id="@+id/instaMojoWebViewFragment"
        android:name="com.qbs.laafresh.ui.fragments.checkout.InstaMojoWebViewFragment"
        android:label="InstaMojoWebViewFragment" >

        <action
            android:id="@+id/action_instaMojoWebViewFragment_to_checkOutFragment"
            app:destination="@id/checkOutFragment"
            />
    </fragment>
</navigation>

