<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">



    <RelativeLayout
        android:id="@+id/relativeAddCoupon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/edCouponCode"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:hint="@string/coupon_code"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:paddingEnd="@dimen/spacing_100"
            android:text=""
            android:textColor="@color/textHeader"
            android:theme="@style/EditTextTheme" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyCoupon"
            android:layout_width="@dimen/spacing_100"
            android:layout_height="@dimen/spacing_40"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="@dimen/spacing_10"
            android:fontFamily="@font/roboto_medium"
            android:text="@string/apply"
            app:cornerRadius="@dimen/spacing_small" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/ReferralNumber"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_below="@+id/btnApplyCoupon"
            android:hint="@string/referral_number"
            android:imeOptions="actionDone"
            android:inputType="number"
            android:paddingEnd="@dimen/spacing_100"
            android:text=""
            android:textColor="@color/textHeader"
            android:theme="@style/EditTextTheme" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/relativeAwayPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/relativeAddCoupon"
        android:layout_marginTop="@dimen/spacing_tiny">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvAwayPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:imeOptions="actionDone"
            android:inputType="textCapSentences"
            android:paddingEnd="@dimen/spacing_100"
            android:text=""
            android:textColor="@color/textHeader"
            android:theme="@style/EditTextTheme" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvAwayPriceValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:fontFamily="@font/roboto_medium"
            android:text=""
            android:textColor="@color/textHeader"
            app:cornerRadius="@dimen/spacing_small" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvAwayDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tvAwayPrice"
            android:layout_centerInParent="true"
            android:layout_marginTop="@dimen/spacing_tiny"
            android:fontFamily="@font/roboto_medium"
            android:gravity="center"
            android:textColor="@color/purple_500"
            android:textSize="@dimen/size_16"
            app:cornerRadius="@dimen/spacing_small" />
    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/relativeCouponApplied"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/relativeAwayPrice"
        android:visibility="gone">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tvCouponCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerInParent="true"
            android:fontFamily="@font/roboto_medium"

            android:text="@string/sub_total"
            android:textColor="@color/purple_700"
            android:textSize="@dimen/size_16" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivRemoveCouponCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerInParent="true"
            android:background="?attr/selectableItemBackground"
            android:padding="@dimen/margin_4" />

    </RelativeLayout>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvSubTotalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/relativeCouponApplied"
        android:layout_alignParentStart="true"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/sub_total"
        android:textColor="@color/textTitle"

        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvSubTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/relativeCouponApplied"
        android:layout_alignParentEnd="true"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvDiscountLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvSubTotalLabel"
        android:layout_alignParentStart="true"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/discount"
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvDiscount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvSubTotalLabel"
        android:layout_alignParentEnd="true"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvShippingCostLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvDiscountLabel"
        android:layout_alignParentStart="true"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/delivery_fee"
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16"

        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvShippingCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvDiscountLabel"
        android:layout_alignParentEnd="true"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16"

        android:visibility="gone" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTax"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvShippingCost"
        android:layout_alignParentStart="true"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/tax"
        android:textColor="@color/textTitle"

        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTaxValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvShippingCost"
        android:layout_alignParentEnd="true"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:text=""
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCoupon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvTax"
        android:layout_alignParentStart="true"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/applied_coupon"
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvCouponValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvTaxValue"
        android:layout_alignParentEnd="true"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:text="0.00"
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvReferral"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_below="@+id/tvCoupon"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/applied_referral"
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvReferralValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/tvCouponValue"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:enabled="false"
        android:text="0.00"
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvOverallShippingCost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_below="@+id/tvReferral"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:text="@string/applied_shipping_cost"
        android:textColor="@color/textTitle"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvOverallShippingCostValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/tvReferralValue"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:text="0.00"
        android:textColor="@color/textHeader"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTotalLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvOverallShippingCost"
        android:layout_alignParentStart="true"
        android:fontFamily="@font/roboto_medium"
        android:paddingTop="@dimen/margin_4"
        android:paddingBottom="@dimen/margin_4"
        android:text="@string/total"
        android:textColor="@color/purple_700"
        android:textSize="@dimen/size_16" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/tvOverallShippingCostValue"
        android:layout_alignParentEnd="true"
        android:fontFamily="@font/roboto_medium"
        android:gravity="end"
        android:paddingTop="@dimen/margin_4"
        android:paddingBottom="@dimen/margin_4"
        android:text=""
        android:textColor="@color/purple_700"

        android:textSize="@dimen/size_16" />

</RelativeLayout>