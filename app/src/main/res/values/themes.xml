<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.LaaFresh" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <!-- Status bar color. -->
<!--        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>-->
        <item name="android:statusBarColor">@color/purple_500</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
<!--        <item name="android:fitsSystemWindows">false</item>-->


        <item name="android:windowLayoutInDisplayCutoutMode">never</item>

        <!-- Status bar color. -->
        <item name="android:windowLightStatusBar">false</item>

    </style>

    <style name="Theme.LaaFresh.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.LaaFresh.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.LaaFresh.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <style name="ToolBarTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="ThemeNavigation">
        <item name="colorPrimary">@color/purple_700</item>
        <item name="colorSurface">@color/purple_500</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="fontFamily">@font/roboto_regular</item>
        <item name="android:textSize">@dimen/font_small</item>
    </style>

    <style name="EditText">
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">match_parent</item>

    </style>

    <style name="TextInputLayoutStyle" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="boxStrokeWidth">2dp</item>
    </style>
    <style name="Toolbar" parent="ThemeOverlay.AppCompat.Dark.ActionBar">
        <item name="android:textSize">30sp</item>
    </style>

    <style name="EditTextTheme" parent="Theme.AppCompat.Light.DarkActionBar">
    <item name="colorControlNormal">@color/viewColor</item>
    <item name="colorControlActivated">@color/purple_700</item>
    <item name="colorControlHighlight">@color/purple_700</item>
    <item name="android:textSize">@dimen/size_18</item>
    </style>
</resources>